@using Localization
@inject LocService SharedLocalizer
@model CanvasAccountRegistration.Web.ViewModel.WhiteListedEmailDomainViewModel

@{
    ViewData["Title"] = SharedLocalizer.GetLocalizedHtmlString("EditWhitelistedEmailDomain");
}

<h1>@SharedLocalizer.GetLocalizedHtmlString("EditWhitelistedEmailDomain")</h1>

<hr />
<div class="row">
    <div class="col-md">
        <form method="post" asp-controller="WhiteListedEmailDomain" asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Domain" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Domain")</label>
                <input asp-for="Domain" value="@Model.Domain" class="form-control" />
                <span asp-validation-for="Domain" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="Id" value="@Model.Id" />
            <input type="hidden" asp-for="CreatedOn" value="@Model.CreatedOn" />

            <div class="form-group mt-3">
                <input type="submit" value="@SharedLocalizer.GetLocalizedHtmlString("Edit")" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="WhiteListedEmailDomain" asp-action="Index">@SharedLocalizer.GetLocalizedHtmlString("Back to List")</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

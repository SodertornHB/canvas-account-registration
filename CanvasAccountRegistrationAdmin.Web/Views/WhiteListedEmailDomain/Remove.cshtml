@using Localization
@inject LocService SharedLocalizer
@model CanvasAccountRegistration.Web.ViewModel.WhiteListedEmailDomainViewModel

@{
    ViewData["Title"] = SharedLocalizer.GetLocalizedHtmlString("DeleteWhitelistedEmailDomain");
}

<h1>@SharedLocalizer.GetLocalizedHtmlString("DeleteWhitelistedEmailDomain")</h1>

<h3>@SharedLocalizer.GetLocalizedHtmlString("Are you sure you want to delete this?")</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            <label>@SharedLocalizer.GetLocalizedHtmlString("Domain")</label>
        </dt>
        <dd class="col-sm-10">
            @Model.Domain
        </dd>
        <dt class="col-sm-2">
            <label asp-for="CreatedOn" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("CreatedOn")</label>
        </dt>
        <dd class="col-sm-10">
            @Model.CreatedOn.ToString("yyyy-MM-dd")
        </dd>
    </dl>
    <form method="post" asp-controller="WhiteListedEmailDomain" asp-action="Remove">
        @Html.HiddenFor(x => x.Id)
        <input type="submit" value="@SharedLocalizer.GetLocalizedHtmlString("Delete")" class="btn btn-danger" /> |
        <a asp-controller="WhiteListedEmailDomain" asp-action="Index">@SharedLocalizer.GetLocalizedHtmlString("Back to List")</a>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

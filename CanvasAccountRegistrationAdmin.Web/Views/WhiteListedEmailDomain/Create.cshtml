@using Localization
@inject LocService SharedLocalizer
@model CanvasAccountRegistration.Web.ViewModel.WhiteListedEmailDomainViewModel

@{
    ViewData["Title"] = SharedLocalizer.GetLocalizedHtmlString("AddWhitelistedEmailDomain");
}

<h1>@SharedLocalizer.GetLocalizedHtmlString("AddWhitelistedEmailDomain")</h1>

<hr />
<div class="row">
    <div class="col-md">
        <form method="post" asp-controller="WhiteListedEmailDomain" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Domain" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Domain")</label>
                <input name="Domain" asp-for="Domain" class="form-control" placeholder="e.g. example.com" />
                <span asp-validation-for="Domain" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="@SharedLocalizer.GetLocalizedHtmlString("Create")" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="WhiteListedEmailDomain" asp-action="Index">@SharedLocalizer.GetLocalizedHtmlString("Back to List")</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
